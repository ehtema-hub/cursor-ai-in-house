{
  "name": "shopverse-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . -c ../qa-automation/quality/eslint.config.js",
    "preview": "vite preview",
    "test": "jest --config ../qa-automation/tests/unit/jest.config.cjs",
    "test:unit": "jest --config ../qa-automation/tests/unit/jest.config.cjs --coverage",
    "test:e2e": "playwright test --config ../qa-automation/tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config ../qa-automation/tests/e2e/playwright.config.ts --ui",
    "test:e2e:chromium": "playwright test --config ../qa-automation/tests/e2e/playwright.config.ts --project=chromium"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^4.1.8",
    "ts-jest": "^29.3.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
