{
  "name": "cursor-ai-in-house-module-6",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo — frontend, backend API, blog API",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "test": "npm run test --prefix frontend",
    "test:unit": "npm run test:unit --prefix frontend",
    "test:e2e": "npm run test:e2e --prefix frontend",
    "test:e2e:chromium": "npm run test:e2e:chromium --prefix frontend",
    "test:backend": "bash qa-automation/tests/integration/run-integration.sh",
    "test:integration": "bash qa-automation/tests/integration/run-integration.sh",
    "qa": "bash qa-automation/scripts/run-all-qa.sh",
    "qa:suite": "bash qa-suite/run_qa_suite.sh",
    "qa:ui": "bash qa-suite/ui-tests/run-ui-tests.sh",
    "qa:lint": "bash qa-suite/code-quality/run-lint.sh",
    "qa:security": "bash qa-suite/security/run-security.sh",
    "qa:perf": "bash qa-suite/performance/run-k6.sh",
    "qa:dashboard": "python3 qa-suite/reporting/generate-dashboard.py"
  }
}
