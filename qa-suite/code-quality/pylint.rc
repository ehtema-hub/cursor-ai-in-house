[MASTER]
ignore=tests,migrations,.venv,htmlcov,qa-suite,qa-automation
jobs=0
py-version=3.12

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    duplicate-code,
    import-outside-toplevel,
    broad-exception-caught

[FORMAT]
max-line-length=100

[DESIGN]
max-args=8
max-attributes=12
max-branches=12
max-statements=50

[REPORTS]
output-format=text
score=yes

[BASIC]
good-names=i,j,k,db,id,_
