{
  "coverage": {
    "minimumPercent": 80,
    "frontendPaths": ["src/lib/**"],
    "backendPaths": ["backend/app/**"]
  },
  "complexity": {
    "maxCyclomatic": 10
  },
  "security": {
    "maxCritical": 0,
    "maxHigh": 0,
    "failOnMediumAbove": 10
  },
  "performance": {
    "maxAvgResponseMs": 500,
    "maxErrorRate": 0.01,
    "k6": {
      "stages": [
        { "duration": "30s", "target": 10 },
        { "duration": "1m", "target": 30 },
        { "duration": "30s", "target": 50 },
        { "duration": "30s", "target": 0 }
      ]
    }
  },
  "lint": {
    "maxEslintErrors": 0,
    "minPylintScore": 7.5
  }
}
